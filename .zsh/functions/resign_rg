resign_rg() {
    # Re-sign Homebrew's ripgrep ad-hoc on this machine so Gatekeeper trusts it.
    # Homebrew bottles ship with a build-machine ad-hoc signature that modern
    # macOS flags ("Apple could not verify rg is free of malware"). Signing
    # locally clears that. Idempotent and safe to run any time.
    local rg_bin="${HOMEBREW_PREFIX:-/opt/homebrew}/bin/rg"
    if [[ ! -x "$rg_bin" ]]; then
        print -u2 "resign_rg: rg not found at $rg_bin"
        return 1
    fi

    # Resolve the symlink to the real Cellar binary (codesign needs the file).
    local real_bin
    real_bin=$(readlink -f "$rg_bin" 2>/dev/null || realpath "$rg_bin" 2>/dev/null || print "$rg_bin")

    xattr -d com.apple.quarantine "$real_bin" 2>/dev/null  # no-op if absent
    if codesign --force --sign - "$real_bin" 2>/dev/null; then
        print "resign_rg: re-signed $real_bin"
    else
        print -u2 "resign_rg: codesign failed for $real_bin"
        return 1
    fi
}
